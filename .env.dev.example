# ============================
# Server Configuration
# ============================
# Port where the application will run
PORT=5001

# ============================
# CORS Configuration
# ============================
# Define allowed origins for CORS. Use "*" for development or specific domains for production
# Examples:
#   CORS_ORIGIN=*
#   CORS_ORIGIN=https://yourdomain.com
#   CORS_ORIGIN=https://yourdomain.com,https://anotherdomain.com
CORS_ORIGIN=*

# ============================
# Authentication
# ============================
# Skip Firebase authentication (useful for local development)
# Set to 'true' to disable auth validation
# WARNING: Never set to true in production!
SKIP_AUTH=true

# ============================
# Firebase Cloud Storage
# ============================
# Name of your Firebase Cloud Storage bucket
# Format: your-project-id.appspot.com
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# ============================
# Stem Separation
# ============================
# Provider to use for audio stem separation
# Supported: 'poyo'
# Default: 'poyo'
SEPARATION_PROVIDER=poyo

# API key for PoYo stem separation service
# Required when SEPARATION_PROVIDER is set to 'poyo'
POYO_API_KEY=your-poyo-api-key

# Base URL for PoYo API
# Default: https://app.poyoclub.com
POYO_API_BASE_URL=https://app.poyoclub.com
